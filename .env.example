# SMS (MSG91) — Phase 2
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""

# Cloudflare R2 — Phase 2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Razorpay — Phase 2
RAZORPAY_KEY_ID=""
