# Database
DATABASE_URL="postgresql://istays:istays_dev_password@localhost:5432/istays_dev?pgbouncer=true&connection_limit=1"
MIGRATION_DATABASE_URL="postgresql://istays:istays_dev_password@localhost:5432/istays_dev"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_api_key"
FROM_EMAIL="noreply@istays.in"

# SMS (MSG91) — Phase 2
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""

# Cloudflare R2 — Phase 2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Razorpay — Phase 2
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Domain (Subdomain Provisioning via Wildcard DNS)
PLATFORM_DOMAIN="istaysin.com"
NEXT_PUBLIC_ROOT_DOMAIN="istaysin.com"

# Sentry — error + performance tracking. Two distinct DSNs so backend and
# frontend issues group separately in the Sentry UI. Leave any DSN empty to
# disable that surface entirely (init becomes a no-op, zero network traffic).

# Express API — packages/api/src/instrument.ts reads this.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=""
SENTRY_RELEASE=""

# Next.js web — apps/web sentry.{client,server,edge}.config.ts read this.
# NEXT_PUBLIC_ prefix is required for browser exposure in Next.js.
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENV=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=""
NEXT_PUBLIC_SENTRY_RELEASE=""

# Source-map upload (CI only). When SENTRY_AUTH_TOKEN is missing, the build
# skips upload silently — local builds and CI without secrets stay clean.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# On-demand revalidation. The API server fires POST /api/revalidate after a
# website-builder save so the public property page's ISR cache refreshes
# immediately. Both halves must agree on the secret. Leave empty to disable —
# pages will still revalidate on the 60s ISR window.
# WEB_URL: where the API can reach the Next.js app server-to-server.
REVALIDATE_SECRET=""
WEB_URL=""
