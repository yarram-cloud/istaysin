# Database
DATABASE_URL="postgresql://istays:istays_dev_password@localhost:5432/istays_dev?pgbouncer=true&connection_limit=1"
MIGRATION_DATABASE_URL="postgresql://istays:istays_dev_password@localhost:5432/istays_dev"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_api_key"
FROM_EMAIL="noreply@istays.in"

# SMS (MSG91) — Phase 2
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""

# Cloudflare R2 — Phase 2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Razorpay — Phase 2
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Domain (Subdomain Provisioning via Wildcard DNS)
PLATFORM_DOMAIN="istaysin.com"
NEXT_PUBLIC_ROOT_DOMAIN="istaysin.com"

# Sentry — error + performance tracking for the API.
# Leave SENTRY_DSN empty to disable Sentry entirely (init becomes a no-op,
# zero overhead, no network traffic). Set in production to capture errors.
# SENTRY_TRACES_SAMPLE_RATE: 0.0–1.0; defaults to 0.1 in production, 1.0 elsewhere.
# SENTRY_RELEASE: typically the git SHA so errors group by release.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=""
SENTRY_RELEASE=""
