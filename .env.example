# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
